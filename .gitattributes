# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.py     text eol=lf
*.js     text eol=lf
*.vue    text eol=lf
*.ts     text eol=lf
*.jsx    text eol=lf
*.tsx    text eol=lf
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.toml   text eol=lf
*.md     text eol=lf
*.css    text eol=lf
*.less   text eol=lf
*.html   text eol=lf
*.sh     text eol=lf
*.sql    text eol=lf

# Windows-specific files
*.ps1    text eol=crlf
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binary files
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    text eol=lf
*.pdf    binary
*.zip    binary
*.tar    binary
*.gz     binary
*.db     binary
*.lock   binary
